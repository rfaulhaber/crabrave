        },
        {
          "type": "text",
          "text": "This is a bulleted list.",
          "subtype": "unordered-list-item"
        },
        {
          "type": "text",
          "text": "I can add text formatting here too.",
          "subtype": "unordered-list-item",
          "formatting": [
            {
              "type": "bold",
              "start": 2,
              "end": 5
            },
            {
              "type": "italic",
              "start": 6,
              "end": 9
            },
            {
              "type": "strikethrough",
              "start": 10,
              "end": 14
            },
            {
              "type": "small",
              "start": 15,
              "end": 25
            },
            {
              "type": "link",
              "start": 26,
              "end": 30,
              "url": "https://www.tumblr.com/staff/653731604461682688/potatoes-are-neat-right-heres-one-cooking-in-a?source=share"
            }
          ]
        },
        {
          "type": "text",
          "text": "We take a break here to enjoy Lucille.",
          "subtype": "quirky",
          "formatting": [
            {
              "type": "color",
              "start": 30,
              "end": 37,
              "hex": "#ff62ce"
            }
          ]
        },
        {
          "type": "text",
          "text": "This is a numbered list.",
          "subtype": "ordered-list-item",
          "formatting": [
            {
              "type": "italic",
              "start": 10,
              "end": 23
            }
          ]
        },
        {
          "type": "text",
          "text": "It’s where you list items.",
          "subtype": "ordered-list-item"
        },
        {
          "type": "text",
          "text": "And numbers appear next to them.",
          "subtype": "ordered-list-item"
        },
        {
          "type": "text",
          "text": "Groundbreaking.",
          "subtype": "ordered-list-item",
          "formatting": [
            {
              "type": "italic",
              "start": 0,
              "end": 15
            },
            {
              "type": "bold",
              "start": 0,
              "end": 15
            },
            {
              "type": "color",
              "start": 0,
              "end": 15,
              "hex": "#00cf35"
            }
          ]
        },
        {
          "type": "text",
          "text": "As one person once said:"
        },
        {
          "type": "text",
          "text": "Look at me, I'm an indented block!",
          "subtype": "indented",
          "formatting": [
            {
              "type": "bold",
              "start": 19,
              "end": 33
            }
          ]
        },
        {
          "type": "text",
          "text": "I'm a quote block! Someone definitely said this at some point.",
          "subtype": "quote",
          "formatting": [
            {
              "type": "bold",
              "start": 6,
              "end": 17
            }
          ]
        },
        {
          "type": "text",
          "text": "Juliet: What is this?\nRomeo: I think we've been summoned for an example chat post again.\nJuliet: Not again...",
          "subtype": "chat",
          "formatting": [
            {
              "type": "bold",
              "start": 0,
              "end": 7
            },
            {
              "type": "bold",
              "start": 22,
              "end": 28
            },
            {
              "type": "bold",
              "start": 89,
              "end": 96
            }
          ]
        },
        {
          "type": "text",
          "text": "We have reached the end. Or have we? "
        },
        {
          "type": "text",
          "text": "Remember to stay hydrated, and follow @changes for Tumblr updates! 💖",
          "formatting": [
            {
              "type": "italic",
              "start": 0,
              "end": 38
            },
            {
              "type": "mention",
              "start": 38,
              "end": 46,
              "blog": {
                "name": "changes",
                "url": "https://www.tumblr.com/blog/view/changes/",
                "uuid": "t:WX5xItRbCiJH_GJDsIdhAQ"
              }
            },
            {
              "type": "italic",
              "start": 38,
              "end": 46
            },
            {
              "type": "italic",
              "start": 46,
              "end": 68
            }
          ]
        },
        {
          "type": "text",
          "text": "You're a curious one, aren't you. Enjoy this potato as a reward."
        },
