        {
          "type": "text",
          "text": "Gotcha! While you’re here, check out some of this text formatting."
        },
        {
          "type": "text",
          "text": "Bigger text ✨",
          "subtype": "heading2"
        },
        {
          "type": "text",
          "text": "This is bold, and this is italics. This is strikethrough. (I'm whispering this in small text.) This is not a suspicious link at all. This text is colourful!",
